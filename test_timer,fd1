REM >test_timer
REM Test program for Timer module
REM This tests all the Timer SWIs
ON ERROR ERROR EXT ERR, REPORT$ + " at line " + STR$(ERL/10)

REM Error codes (CMHG error base &840)
ERR_OUT_OF_RANGE% = &840
ERR_ALREADY_CLAIMED% = &841
ERR_NOT_CLAIMED% = &842
ERR_INVALID_FLAGS% = &843
ERR_RESERVED_FLAGS% = &844

REM SWI base for Timer module
Timer_Base% = &58B80

PRINT "Timer Module Test Program"
PRINT "========================="
PRINT

REM Test 1: Timer_ReturnNumber
REM Standard SWI - error would raise BASIC error
REM Output: R0 = number of timers
PRINT "Test 1: Timer_ReturnNumber"
SYS "Timer_ReturnNumber", 0 TO num_timers%
PRINT "  Number of timers available: ";num_timers%
IF num_timers% <= 0 THEN PRINT "  FAILED: Expected > 0 timers":END
PRINT "  PASSED"
PRINT

REM Test 2: Timer_Claim with valid timer
REM Standard SWI - error would raise BASIC error
REM Output: R2 = timer rate
PRINT "Test 2: Timer_Claim (valid timer)"
SYS "Timer_Claim", 0, 0, 1000, 0 TO ,,rate%
PRINT "  Timer 0 claimed, rate: ";rate%
IF rate% = 0 THEN PRINT "  FAILED: Expected non-zero rate":END
PRINT "  PASSED"
PRINT

REM Test 3: Timer_Claim with already claimed timer (should fail)
REM Use XSWI since we're explicitly checking for the error
PRINT "Test 3: Timer_Claim (already claimed - should fail)"
test_passed% = FALSE
SYS "XTimer_Claim", 0, 0, 1000, 0 TO r0%,r1%,r2%;flags%
IF flags% AND 1 THEN
  err_num% = r0%!0
  IF err_num% = ERR_ALREADY_CLAIMED% THEN
    test_passed% = TRUE
  ENDIF
ENDIF
IF test_passed% THEN
  PRINT "  PASSED (error ";err_num%;")"
ELSE
  PRINT "  FAILED: Expected error code ";ERR_ALREADY_CLAIMED%;" got ";err_num%
  END
ENDIF
PRINT

REM Test 4: Timer_Claim with out of range timer (should fail)
REM Use XSWI since we're explicitly checking for the error
PRINT "Test 4: Timer_Claim (out of range - should fail)"
test_passed% = FALSE
SYS "XTimer_Claim", 0, 99, 1000, 0 TO r0%,r1%,r2%;flags%
IF flags% AND 1 THEN
  err_num% = r0%!0
  IF err_num% = ERR_OUT_OF_RANGE% THEN
    test_passed% = TRUE
  ENDIF
ENDIF
IF test_passed% THEN
  PRINT "  PASSED (error ";err_num%;")"
ELSE
  PRINT "  FAILED: Expected error code ";ERR_OUT_OF_RANGE%;" got ";err_num%
  END
ENDIF
PRINT

REM Test 5: Timer_SetRate
REM Standard SWI - error would raise BASIC error
REM Output: R2 = timer rate
PRINT "Test 5: Timer_SetRate"
SYS "Timer_SetRate", 0, 0, 2000000 TO ,,new_rate%
PRINT "  Timer 0 rate set to: ";new_rate%
IF new_rate% <> 2000000 THEN PRINT "  FAILED: Expected 2000000":END
PRINT "  PASSED"
PRINT

REM Test 6: Timer_Convert
REM Standard SWI - error would raise BASIC error
REM Output: R2 = converted value
PRINT "Test 6: Timer_Convert"
SYS "Timer_Convert", 0, 0, 5000 TO ,,converted%
PRINT "  Converted value: ";converted%
IF converted% <> 5000 THEN PRINT "  FAILED: Expected 5000":END
PRINT "  PASSED"
PRINT

REM Test 7: Timer_Release
REM Standard SWI - error would raise BASIC error
REM Output: None
PRINT "Test 7: Timer_Release"
SYS "Timer_Release", 0, 0
PRINT "  Timer 0 released"
PRINT "  PASSED"
PRINT

REM Test 8: Timer_Release on unclaimed timer (should fail)
REM Use XSWI since we're explicitly checking for the error
PRINT "Test 8: Timer_Release (not claimed - should fail)"
test_passed% = FALSE
SYS "XTimer_Release", 0, 0 TO r0%;flags%
IF flags% AND 1 THEN
  err_num% = r0%!0
  IF err_num% = ERR_NOT_CLAIMED% THEN
    test_passed% = TRUE
  ENDIF
ENDIF
IF test_passed% THEN
  PRINT "  PASSED (error ";err_num%;")"
ELSE
  PRINT "  FAILED: Expected error code ";ERR_NOT_CLAIMED%;" got ";err_num%
  END
ENDIF
PRINT

REM Test 9: Timer_ReturnNumber with invalid flags (should fail)
REM Use XSWI since we're explicitly checking for the error
PRINT "Test 9: Timer_ReturnNumber (invalid flags - should fail)"
test_passed% = FALSE
SYS "XTimer_ReturnNumber", 1 TO r0%;flags%
IF flags% AND 1 THEN
  err_num% = r0%!0
  IF err_num% = ERR_INVALID_FLAGS% THEN
    test_passed% = TRUE
  ENDIF
ENDIF
IF test_passed% THEN
  PRINT "  PASSED (error ";err_num%;")"
ELSE
  PRINT "  FAILED: Expected error code ";ERR_INVALID_FLAGS%;" got ";err_num%
  END
ENDIF
PRINT

REM Test 10: Claim multiple timers
REM Standard SWI - error would raise BASIC error
REM Output: R2 = timer rate
PRINT "Test 10: Claim multiple timers"
all_claimed% = TRUE
FOR timer% = 0 TO num_timers% - 1
  SYS "Timer_Claim", 0, timer%, 1000, 0 TO ,,rate%
  IF rate% = 0 THEN
    all_claimed% = FALSE
    PRINT "  FAILED on timer ";timer%
  ENDIF
NEXT
IF all_claimed% THEN
  PRINT "  All ";num_timers%;" timers claimed successfully"
  PRINT "  PASSED"
ELSE
  END
ENDIF
PRINT

REM Clean up - release all timers
FOR timer% = 0 TO num_timers% - 1
  SYS "Timer_Release", 0, timer%
NEXT

PRINT "========================="
PRINT "All tests completed successfully!"
